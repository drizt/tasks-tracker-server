  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/prompts": "^2.4.9",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:create-db": "node dist/create-db.js",
    "build": "npm run prisma:generate && npm run compile",
    "test": "NODE_OPTIONS='--no-warnings --experimental-vm-modules' jest",
    "clean": "rimraf dist src/generated",
    "compile": "tsc --build",
    "lint": "eslint",
    "lint:sql": "sqlfluff lint prisma/migrations",
    "format:sql": "sqlfluff fix prisma/migrations",
    "migrate:deploy": "prisma migrate deploy",
    "check:schema": "prisma migrate diff --from-migrations prisma/migrations --to-schema prisma/schema.prisma --exit-code",
    "prisma:generate": "prisma generate --no-hints"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/websocket": "^11.2.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ajv": "^8.20.0",
    "audic": "^3.0.2",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "json-rpc-2.0": "^1.7.1",
    "prompts": "^2.4.2",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  }
}
